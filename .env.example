# Bot Configuration
BOT_TOKEN=your_bot_token_here

# First admin user (Telegram ID)
FIRST_ADMIN_ID=751579780

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=budget_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_EXTERNAL_PORT=5432
DB_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_EXTERNAL_PORT=6379
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}

# RabbitMQ Configuration
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=your_rabbitmq_password
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_EXTERNAL_PORT=5679
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_MANAGEMENT_EXTERNAL_PORT=15678
RABBITMQ_URL=amqp://${RABBITMQ_USER}:${RABBITMQ_PASSWORD}@${RABBITMQ_HOST}:${RABBITMQ_PORT}//

# Application Ports
BOT_PORT=5000
BOT_EXTERNAL_PORT=5000
FLOWER_PORT=5555
FLOWER_EXTERNAL_PORT=5555

# MinIO Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=your_minio_access_key
MINIO_SECRET_KEY=your_minio_secret_key
MINIO_BUCKET=budget-files
MINIO_SECURE=false
MINIO_PORT=9000
MINIO_EXTERNAL_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_CONSOLE_EXTERNAL_PORT=9001

 
INTERNAL_TRANSFER_KEYWORDS=your_name,your_surname,перевод между своими счетами
